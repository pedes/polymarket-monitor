# ── Polymarket ──────────────────────────────────────────────────────────────────
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# ── NOAA ────────────────────────────────────────────────────────────────────────
NOAA_API_URL=https://api.weather.gov
NOAA_USER_AGENT=polymarket-monitor/1.0   # NOAA requires a descriptive UA string

# ── Database ─────────────────────────────────────────────────────────────────────
DB_PATH=polymarket_monitor.db

# ── Scheduling ───────────────────────────────────────────────────────────────────
POLL_INTERVAL_MINUTES=15

# ── Alert thresholds ─────────────────────────────────────────────────────────────
DIVERGENCE_THRESHOLD=20.0       # percentage points
ALERT_COOLDOWN_HOURS=4          # min hours between repeat alerts per market

# ── Telegram (optional) ──────────────────────────────────────────────────────────
# Create a bot via @BotFather, then invite it to a chat and grab the chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord (optional) ───────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Misc ─────────────────────────────────────────────────────────────────────────
DRY_RUN=false
LOG_LEVEL=INFO
